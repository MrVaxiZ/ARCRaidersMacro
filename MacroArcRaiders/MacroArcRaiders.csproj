<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
	<PublishSingleFile>true</PublishSingleFile>
	<SelfContained>true</SelfContained>
	<UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	
	<PublishReadyToRun>true</PublishReadyToRun>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Confirm.png" />
    <None Remove="Continue.png" />
    <None Remove="Free_Loadout.png" />
    <None Remove="Free_Loadout_NotClicked.png" />
    <None Remove="Ready_Up.png" />
    <None Remove="Start.png" />
    <None Remove="Stella_Montis.png" />
    <None Remove="Stella_Montis_NotClicked.png" />
    <None Remove="Surrender.png" />
    <None Remove="Surrender_black.png" />
    <None Remove="Yes.png" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="templates\Confirm.png" />
    <EmbeddedResource Include="templates\Continue.png" />
    <EmbeddedResource Include="templates\Free_Loadout.png" />
    <EmbeddedResource Include="templates\Free_Loadout_NotClicked.png" />
    <EmbeddedResource Include="templates\Ready_Up.png" />
    <EmbeddedResource Include="templates\Start.png" />
    <EmbeddedResource Include="templates\Stella_Montis.png" />
    <EmbeddedResource Include="templates\Stella_Montis_NotClicked.png" />
    <EmbeddedResource Include="templates\Surrender.png" />
